PORT=8000
NODE_ENV=development

# Mongo
MONGO_URI=your_mongodb_connection_string

# Auth
JWT_SECRET=your_jwt_secret_key

# Razorpay (required for taking payments)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxx

# Razorpay webhooks (recommended): set this only if you configure webhook in Razorpay dashboard
RAZORPAY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxx

# Admin-only endpoints protection
# NOTE: Offline cash registration endpoint currently does NOT enforce ADMIN_API_KEY.
ADMIN_API_KEY=

# Optional: business timezone offset in minutes (IST = 330)
BUSINESS_TZ_OFFSET_MINUTES=330

# Payment pricing shown to customer (optional)
# Commission is calculated as: subtotal * (PAYMENT_COMMISSION_PCT/100) + PAYMENT_COMMISSION_FLAT_INR
# GST is calculated on the commission amount.
PAYMENT_COMMISSION_PCT=0
PAYMENT_COMMISSION_FLAT_INR=0
PAYMENT_GST_PCT=0

# Testing-only: force all membership totals (online + offline) to this INR amount.
# Example: set to 1 to charge ₹1 for every plan.
FORCE_TEST_AMOUNT_INR=



############################
# WhatsApp Cloud API (Meta)
############################

# API version (either name works)
WA_API_VERSION=v19.0
# WA_VERSION=v19.0

# From Meta WhatsApp Cloud API
WA_PHONE_ID=
WA_TOKEN=

# Default country code for numbers without cc (India = 91)
WA_DEFAULT_COUNTRY_CODE=91

